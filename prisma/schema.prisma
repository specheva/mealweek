generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Auth ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  onboarded     Boolean   @default(false)
  createdAt     DateTime  @default(now())

  householdId   String?
  household     Household?  @relation(fields: [householdId], references: [id])
  meals         Meal[]
}

model Household {
  id        String   @id @default(cuid())
  name      String   @default("My Household")
  createdAt DateTime @default(now())

  members   User[]
  meals     Meal[]
  weekPlans WeekPlan[]
}

// ── Meals ───────────────────────────────────────────────────────────

model Meal {
  id              String           @id @default(cuid())
  title           String
  description     String?
  sourceUrl       String?
  sourceType      String?
  imageUrl        String?
  prepTimeMinutes Int?
  cookTimeMinutes Int?
  difficulty      String           @default("medium")
  cuisine         String?
  category        String?
  notes           String?
  isFavorite      Boolean          @default(false)
  isComplete      Boolean          @default(true)
  timesCooked     Int              @default(0)
  lastCookedAt    DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  createdById     String?
  createdBy       User?            @relation(fields: [createdById], references: [id])
  householdId     String?
  household       Household?       @relation(fields: [householdId], references: [id])

  tags        MealTag[]
  ingredients MealIngredient[]
  planEntries PlanEntry[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  color String?

  meals MealTag[]
}

model MealTag {
  mealId String
  tagId  String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mealId, tagId])
}

model MealIngredient {
  id       String  @id @default(cuid())
  mealId   String
  name     String
  quantity Float?
  unit     String?
  note     String?
  category String?

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
}

// ── Planning ────────────────────────────────────────────────────────

model WeekPlan {
  id          String      @id @default(cuid())
  weekStart   DateTime
  createdAt   DateTime    @default(now())

  householdId String?
  household   Household?  @relation(fields: [householdId], references: [id])

  entries PlanEntry[]

  @@unique([householdId, weekStart])
}

model PlanEntry {
  id         String   @id @default(cuid())
  weekPlanId String
  mealId     String
  dayOfWeek  Int
  slot       String   @default("dinner")
  sortOrder  Int      @default(0)

  weekPlan WeekPlan @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  meal     Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@unique([weekPlanId, dayOfWeek, slot, mealId])
}
